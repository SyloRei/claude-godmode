{
  "includeCoAuthoredBy": false,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/hooks/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",

      "Bash(git *)",
      "Bash(gh *)",

      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(vitest *)",
      "Bash(jest *)",

      "Bash(cargo *)",
      "Bash(rustfmt *)",

      "Bash(go *)",
      "Bash(golangci-lint *)",

      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(mypy *)",
      "Bash(pyright *)",

      "Bash(bundle *)",
      "Bash(ruby *)",
      "Bash(rake *)",
      "Bash(rspec *)",

      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",

      "Bash(jq *)",
      "Bash(shellcheck *)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(tree *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(chmod *)",

      "Bash(* --version)",
      "Bash(* --help)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force *)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard *)",
      "Bash(* DROP TABLE *)",
      "Bash(* DROP DATABASE *)"
    ]
  },
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-compact.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
